name: Generate Keystore (SADECE BİR KEZ ÇALIŞTIR)

on:
  workflow_dispatch:

jobs:
  generate:
    name: Keystore Oluştur
    runs-on: ubuntu-latest

    steps:
      - name: Java kur
        uses: actions/setup-java@v4
        with:
          distribution: temurin
          java-version: "17"

      - name: Keystore oluştur
        run: |
          keytool -genkeypair \
            -v \
            -keystore asgard_release.keystore \
            -alias asgard \
            -keyalg RSA \
            -keysize 2048 \
            -validity 10000 \
            -storepass Darkness4577. \
            -keypass Darkness4577. \
            -dname "CN=Asgard, OU=Mobile, O=Asgard, L=Istanbul, S=Istanbul, C=TR"
          echo "✅ Keystore oluşturuldu"
          ls -lh asgard_release.keystore

      - name: Base64 çıktısı al
        run: |
          BASE64=$(base64 -w 0 asgard_release.keystore)
          echo "======= AŞAĞIDA YAZANI KOPYALA ======="
          echo "$BASE64"
          echo "======================================="
          echo "Bu base64 değerini RELEASE_KEYSTORE_BASE64 secret olarak ekle"

      - name: Keystore dosyasını artifact olarak kaydet
        uses: actions/upload-artifact@v4
        with:
          name: asgard-keystore
          path: asgard_release.keystore
          retention-days: 1
